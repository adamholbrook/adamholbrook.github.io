---

<nav>
  <div class="container nav-inner">
    <a href="#hero" class="nav-logo">AH<span class="dot">.</span></a>
    <ul class="nav-links">
      <li><a href="#experience">Experience</a></li>
      <li><a href="#skills">Skills</a></li>
      <li><a href="#achievements">Achievements</a></li>
      <li><a href="#automation-status">Live Status</a></li>
      <li>
        <a href="mailto:arholbrook90@gmail.com" class="nav-cta">Contact</a>
      </li>
    </ul>
    <button class="nav-toggle" aria-label="Toggle menu" id="navToggle">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1rem 0;
    background: rgba(13, 27, 42, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 198, 167, 0.1);
    transition: background 0.3s;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--white);
    letter-spacing: -0.02em;
  }

  .nav-logo .dot {
    color: var(--teal);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--slate-light);
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--white);
  }

  .nav-cta {
    padding: 0.45rem 1.2rem;
    border: 1px solid var(--teal);
    border-radius: 6px;
    color: var(--teal) !important;
    font-family: var(--font-mono);
    font-size: 0.8rem !important;
    transition: background 0.2s, color 0.2s !important;
  }

  .nav-cta:hover {
    background: var(--teal);
    color: var(--navy) !important;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--white-soft);
    border-radius: 2px;
    transition: transform 0.3s;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background: var(--navy-mid);
      padding: 1.5rem 2rem;
      border-bottom: 1px solid rgba(0, 198, 167, 0.1);
      gap: 1.25rem;
    }

    .nav-links.open {
      display: flex;
    }

    .nav-toggle {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.getElementById('navToggle');
  const links = document.querySelector('.nav-links');
  toggle?.addEventListener('click', () => links?.classList.toggle('open'));
</script>
