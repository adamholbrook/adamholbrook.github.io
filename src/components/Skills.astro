---
const skillGroups = [
  {
    category: 'Test Automation',
    icon: '⚙',
    skills: ['Playwright', 'Cypress', 'Selenium', 'WebDriver', 'Cucumber', 'Behave (BDD)', 'Mocha', 'Jest'],
  },
  {
    category: 'Languages',
    icon: '</> ',
    skills: ['TypeScript', 'JavaScript', 'Python'],
  },
  {
    category: 'CI / CD & Load',
    icon: '🔄',
    skills: ['GitHub Actions', 'CircleCI', 'Buildkite', 'Concourse', 'Jenkins', 'Grafana K6'],
  },
  {
    category: 'API & Tooling',
    icon: '🔌',
    skills: ['Postman', 'Newman', 'Docker', 'Docker Compose', 'Git', 'AWS (Cognito, S3, DynamoDB)'],
  },
  {
    category: 'Management & Process',
    icon: '👥',
    skills: ['Jira', 'Confluence', 'Targetprocess', 'Stakeholder Reporting', 'Agile / Scrum', 'Shift-Left QA'],
  },
  {
    category: 'Leadership',
    icon: '🎯',
    skills: ['Line Management', 'Mentoring', 'Roadmap Planning', 'Interviewing & Onboarding', 'KPI Reporting'],
  },
];
---

<section id="skills">
  <div class="container">
    <p class="section-label">What I Work With</p>
    <h2 class="section-title">Skills & Tools</h2>

    <div class="skills-grid">
      {skillGroups.map((group) => (
        <div class="skill-card">
          <div class="skill-card-header">
            <span class="skill-icon" aria-hidden="true">{group.icon}</span>
            <h3>{group.category}</h3>
          </div>
          <ul class="skill-list">
            {group.skills.map((s) => (
              <li>
                <span class="skill-marker" aria-hidden="true" />
                {s}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .skill-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(176, 186, 201, 0.1);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.3s, transform 0.2s;
  }

  .skill-card:hover {
    border-color: rgba(0, 198, 167, 0.3);
    transform: translateY(-2px);
  }

  .skill-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(176, 186, 201, 0.08);
  }

  .skill-icon {
    font-size: 1.2rem;
    line-height: 1;
  }

  .skill-card-header h3 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--white);
  }

  .skill-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skill-list li {
    font-size: 0.875rem;
    color: var(--slate-light);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .skill-marker {
    display: block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--teal);
    flex-shrink: 0;
  }
</style>
